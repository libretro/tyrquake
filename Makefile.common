ifeq ($(platform), ctr)
SOURCES_C += \
				 $(LIBRETRO_COMM_DIR)/net/net_compat.c \
				 $(LIBRETRO_COMM_DIR)/net/net_socket.c
else ifneq ($(STATIC_LINKING),1)
SOURCES_C += \
				 $(LIBRETRO_COMM_DIR)/net/net_compat.c \
				 $(LIBRETRO_COMM_DIR)/net/net_socket.c
endif
else
SOURCES_C += $(CORE_DIR)/common/net_none.c
endif

ifeq ($(USE_CODEC_FLAC),1)
INCFLAGS  += -I$(LIBFLAC_DIR)/include
SOURCES_C += \
				 $(LIBFLAC_DIR)/bitreader.c \
				 $(LIBFLAC_DIR)/crc.c \
				 $(LIBFLAC_DIR)/fixed.c \
				 $(LIBFLAC_DIR)/float.c \
				 $(LIBFLAC_DIR)/format.c \
				 $(LIBFLAC_DIR)/lpc.c \
				 $(LIBFLAC_DIR)/md5.c \
				 $(LIBFLAC_DIR)/memory.c \
				 $(LIBFLAC_DIR)/ogg_decoder_aspect.c \
				 $(LIBFLAC_DIR)/ogg_mapping.c \
				 $(LIBFLAC_DIR)/stream_decoder.c
endif

ifeq ($(USE_CODEC_VORBIS),1)
# Vorbis is decoded with the fixed-point Tremor (libvorbisidec) decoder
# rather than the float libvorbis.  Tremor's integer-only IMDCT yields
# bit-identical int16 PCM on every platform/FPU, so music decode is
# deterministic and there is no float->int16 quantization pass.  The
# snd_vorbis.c wrapper takes its VORBIS_USE_TREMOR code path accordingly;
# the -DVORBIS_USE_TREMOR define is set by the driver makefiles.
# snd_vorbis.c reaches Tremor through <tremor/ivorbisfile.h> (-I deps) and
# Tremor's own sources self-include via quotes, so the deps/tremor directory
# is deliberately NOT on the -I path: putting it there makes its generically
# named headers (block.h, os.h, misc.h, window.h...) shadow system headers of
# the same name on case-insensitive filesystems -- e.g. macOS CoreFoundation's
# <Block.h> would resolve to deps/tremor/block.h and fail to build.
INCFLAGS  += -I$(CORE_DIR)/deps \
				 -I$(LIBOGG_DIR)/include

SOURCES_C += \
				 $(TREMOR_DIR)/block.c \
				 $(TREMOR_DIR)/codebook.c \
				 $(TREMOR_DIR)/floor0.c \
				 $(TREMOR_DIR)/floor1.c \
				 $(TREMOR_DIR)/info.c \
				 $(TREMOR_DIR)/mapping0.c \
				 $(TREMOR_DIR)/mdct.c \
				 $(TREMOR_DIR)/registry.c \
				 $(TREMOR_DIR)/res012.c \
				 $(TREMOR_DIR)/sharedbook.c \
				 $(TREMOR_DIR)/synthesis.c \
				 $(TREMOR_DIR)/vorbisfile.c \
				 $(TREMOR_DIR)/window.c

SOURCES_C += $(LIBOGG_DIR)/src/bitwise.c \
				 $(LIBOGG_DIR)/src/framing.c

# Float libvorbis: used only when float audio output is negotiated; decodes
# straight to float (vs Tremor's int16, which stays the default).  Vendored
# decode-only -- the encode machinery (psy/envelope/FFT) is replaced by no-op
# stubs in decode_stubs.c, since every reference to it sits behind an encode-
# only guard never taken on the decode path.  Symbol-namespaced to fv_* via
# fvorbis_rename.h (force-included below) so it links beside Tremor without
# colliding on the shared ov_*/vorbis_* names; the single vendored libogg is
# shared by both (its symbols are deliberately not renamed).
#
# deps/libvorbis/lib is kept OFF the global -I path: its generic header names
# (block.h, os.h, misc.h, window.h, info.h, ...) would shadow system headers
# of the same name, the same hazard documented above for deps/tremor.  The
# per-object CFLAGS add it locally to the vendored TUs only.  snd_vorbis_float.c
# needs just the public vorbis headers and namespaces the few ov_* entry points
# it calls in-source, so it only takes -I.../include.
LIBVORBIS_SOURCES = \
				 $(LIBVORBIS_DIR)/lib/bitrate.c \
				 $(LIBVORBIS_DIR)/lib/block.c \
				 $(LIBVORBIS_DIR)/lib/codebook.c \
				 $(LIBVORBIS_DIR)/lib/decode_stubs.c \
				 $(LIBVORBIS_DIR)/lib/floor0.c \
				 $(LIBVORBIS_DIR)/lib/floor1.c \
				 $(LIBVORBIS_DIR)/lib/info.c \
				 $(LIBVORBIS_DIR)/lib/lookup.c \
				 $(LIBVORBIS_DIR)/lib/lpc.c \
				 $(LIBVORBIS_DIR)/lib/lsp.c \
				 $(LIBVORBIS_DIR)/lib/mapping0.c \
				 $(LIBVORBIS_DIR)/lib/mdct.c \
				 $(LIBVORBIS_DIR)/lib/registry.c \
				 $(LIBVORBIS_DIR)/lib/res0.c \
				 $(LIBVORBIS_DIR)/lib/sharedbook.c \
				 $(LIBVORBIS_DIR)/lib/synthesis.c \
				 $(LIBVORBIS_DIR)/lib/vorbisfile.c \
				 $(LIBVORBIS_DIR)/lib/window.c

SOURCES_C += $(LIBVORBIS_SOURCES) $(CORE_DIR)/common/snd_vorbis_float.c

$(LIBVORBIS_SOURCES:.c=.o): CFLAGS += \
	-include $(LIBVORBIS_DIR)/lib/fvorbis_rename.h \
	-I$(LIBVORBIS_DIR)/lib -I$(LIBVORBIS_DIR)/include \
	-Wno-maybe-uninitialized
endif
